<!DOCTYPE html>
<html lang="en" class="reduce-fouce">
<head>
    <meta charset=utf-8>
    <meta http-equiv=x-ua-compatible content="ie=edge">
    <meta name=viewport content="width=device-width,initial-scale=1">
    <meta name="robots" content="noindex, nofollow">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@shoelace-style/shoelace@2.15.0/cdn/themes/light.css" />
    <script type="module" src="https://cdn.jsdelivr.net/npm/@shoelace-style/shoelace@2.15.0/cdn/shoelace-autoloader.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/index.css">
    <script src="/assets/js/card_control.js" defer></script>

    <title>eegmanylabs</title>
</head>
<body>
  <div class="colourPickers" style="position:fixed;left:20px;top:100px;padding:5px;border:solid 1px black;background-color:white;">
    <div style="display:flex; align-items:center;">
      <sl-color-picker label="Select a color" style="padding: 5px" class="navPicker"></sl-color-picker> Nav-bar colour
    </div>
    <div style="display:flex; align-items:center;">
      <sl-color-picker label="Select a color" style="padding: 5px" class="bgPicker"></sl-color-picker> Background colour
    </div>
    <div style="display:flex; align-items:center;">
      <sl-color-picker label="Select a color" style="padding: 5px" class="footPicker"></sl-color-picker> Footer colour
    </div>
  </div>
  <nav id="menu">
    <a id="logo" href="/"><img id="logo" src="/assets/images/logo.png"></a>
    <a href="javascript:void(0);" class="icon" onclick="showResponsiveMenu()">
      <sl-icon library="fa" name="fas-bars"></sl-icon>
    </a>
    <ul class="topnav" id="myTopnav">
    {% for branch in root.branches %}
        {% if branch.buildPage %}
            <li><a href="/{{ branch.name }}/">{{ branch.name }}</a></li>
        {% endif %}
    {% endfor %}
    </ul>
  </nav>
  <div id="body-container">{# pushes down the footer when there is little content #}
    <div id="content">
      {% block main %}{% endblock %}
    </div>
  </div>
  <footer>
    {% for leaf in root.leaves %}
      {% include 'section_leaf.jinja2' %}
    {% endfor %}
    <span id="copyright-reference">&copy; 2024 eegmanylabs</span>
  </footer>

{# shoelace snippet to add font awesome #}
<script type="module">
  import { registerIconLibrary } from 'https://cdn.jsdelivr.net/npm/@shoelace-style/shoelace@2.15.0/cdn/utilities/icon-library.js';

  registerIconLibrary('fa', {
    resolver: name => {
      const filename = name.replace(/^fa[rbs]-/, '');
      let folder = 'regular';
      if (name.substring(0, 4) === 'fas-') folder = 'solid';
      if (name.substring(0, 4) === 'fab-') folder = 'brands';
      return `https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.5.2/svgs/${folder}/${filename}.svg`;
    },
    mutator: svg => svg.setAttribute('fill', 'currentColor')
  });
</script>
<script>
function showResponsiveMenu() {
  var navBar = document.getElementById("myTopnav");
  if (navBar.className === "topnav") {
    // Show menu in responsive state by adding responsive class to element
    navBar.classList.add("responsive");
  } else {
    // Hide menu by resetting to just the topnav class
    navBar.className = "topnav";
  }
}
</script>
<script type="module">
  await Promise.race([
    // Load all custom elements
    Promise.allSettled([
      customElements.whenDefined('sl-select'),
      customElements.whenDefined('sl-card'),
    ]),
    // Resolve after two seconds
    new Promise(resolve => setTimeout(resolve, 1500))
  ]);

  // Remove the class, showing the page content
  document.documentElement.classList.remove('reduce-fouce');
</script>
<script>
  function changeColour(value, elSelector) {
    el = document.querySelector(elSelector)
    el.style.backgroundColor = value
  }

  function addChangeColour(elFrom, elTo) {
    el = document.querySelector(elFrom)
    el.addEventListener(
      "sl-change",
      function(e) { changeColour(e.currentTarget.value, elTo) }
    )
  }

  function setInitialCol(pickerEl, pageEl) {
    picker = document.querySelector(pickerEl)
    el = document.querySelector(pageEl)

    picker.value = window.getComputedStyle(el).backgroundColor
  }

  function setupPickers(pickerEl, pageEl) {
    setInitialCol(pickerEl, pageEl)
    addChangeColour(pickerEl, pageEl)
  }

  setupPickers(".navPicker", "nav#menu")
  setupPickers(".bgPicker", "body")
  setupPickers(".footPicker", "footer")
</script>

</body>
</html>